#!/opt/homebrew/bin/bash


# This script uses pandoc to turn all the markdown files under "markdown" into html files under html

#!/opt/homebrew/bin/bash

# reset the output directory
rm -rf html
mkdir -p html

# Loop through every .md file in the markdown directory
for md_file in markdown/*.md; do
    # Check if the file exists (prevents errors if the directory is empty)
    [ -e "$md_file" ] || continue

    # Get the filename without the path and extension
    filename=$(basename "$md_file" .md)

    echo "Converting $filename..."

    # Run pandoc
    pandoc "$md_file" -o "html/$filename.html"
done

echo "Done! Check the 'html' folder."